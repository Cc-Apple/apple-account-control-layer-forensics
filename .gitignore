# Public repository ignore rules
# Prevent accidental upload of raw logs, diagnostic archives, backups,
# databases, private screenshots, generated outputs, and local artifacts.

# Raw iOS logs / diagnostics
*.ips
*.ips.ca.synced
*.crash
*.spin
*.diag
*.logarchive

# Raw archives
*.zip
*.tar
*.tar.gz
*.tgz
*.gz
*.7z
*.rar

# iOS backup / forensic databases
Manifest.db
Manifest.plist
Status.plist
Info.plist
DDNABackup.plist
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm

# Raw evidence folders
raw_logs/
raw_artifacts/
raw_debug/
raw_sysdiagnose/
debug/
Debug/
sysdiagnose/
Sysdiagnose/
diagnostics/
Diagnostics/
external_debug/
external_sysdiagnose/
full_backup/
backup/
iMazing/
Manifest/

# Private screenshots / media
*.heic
*.HEIC
*.jpg
*.jpeg
*.png
*.mov
*.mp4

# Generated analysis outputs
analysis_output/*.json
analysis_output/*.csv
analysis_output/*.txt
!analysis_output/README.md

# Python / environment
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
ENV/

# OS / editor noise
.DS_Store
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
*.bak
*.old
